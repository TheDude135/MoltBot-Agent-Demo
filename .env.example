# MoltBot Ninja API key — bearer credential. Mint at:
#   https://app.moltbot.ninja → API Keys → Create
#
# Required scopes for this demo:
#   - deployments:read
#   - agents:write
#   - blueprints:read
#   - blueprints:deploy
#
# OPTIONAL — adds the voice install flow:
#   - voice:read              (list voice deployments in PickVoiceDeploymentPhase)
#   - voice:install-bundles   (mint install bundles at TTMA)
#   - voice:install           (install voice gateway on a sub-agent at Ninja)
#   - voice:uninstall         (uninstall voice gateway; demo doesn't ship this UI)
#
# The key MUST be scoped to:
#   - the Ninja fleet deployment you want to deploy onto, AND
#   - any TTMA voice deployment you want to install voice from.
# Per-instance scope is enforced on both APIs.
MBN_API_KEY=mbn_live_REPLACE_ME

# Ninja public REST API. Production: https://api.moltbot.ninja
# Local emulator (Firebase Functions): http://localhost:5001/<project>/us-central1/api
MBN_API_BASE=https://api.moltbot.ninja

# TTMA voice-api base. Same Bearer key as MBN_API_KEY; the apiKeys collection
# is shared between the Ninja and TTMA Cloud Functions.
TTMA_API_BASE=https://api.talktomyagent.io
