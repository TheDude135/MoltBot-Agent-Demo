# MoltBot Ninja API key — bearer credential. Mint at:
#   https://app.moltbot.ninja → API Keys → Create
#
# Required scopes for this demo:
#   - deployments:read
#   - agents:write
#   - blueprints:read
#   - blueprints:deploy
#
# The key MUST be scoped to the deployments you want to deploy to
# (the API blocks cross-deployment use even with valid scopes).
MBN_API_KEY=mbn_live_REPLACE_ME

# Public API base URL. Production:    https://api.moltbot.ninja
# Local emulator (Firebase Functions): http://localhost:5001/<project>/us-central1/api
MBN_API_BASE=https://api.moltbot.ninja
